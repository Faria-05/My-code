#include<stdio.h>
int main()
{
    int n,i,sum=0,a[100];
    printf("enter the number of elements:");
    scanf("%d",&n);
    
         
    for(i=0;i<n;i++)
    
    {
         printf("Enter no %d element:",i+1);
       scanf("%d",&a[i]);
         if(a[i]%2==0)
         {
          sum+=a[i];
         }
         
    }
    printf("Sum of elements are %d",sum);
    return 0;
}
