#include<stdio.h>
#include<string.h>
int main()
{
  char name[500];
    printf("Enter the name:");
    fgets(name,sizeof(name),stdin);
    name[strcspn(name,"\n")]='\0';
    if(name[0]=='M'&&name[1]=='d')
    {
         name[0]=' ';
         name[1]=' ';
         name[2]=' ';
    }
     
    printf("%s",name);
   return 0;
}
