#include<stdio.h>
#include<string.h>
int main()
{
    char a[500];
    int len=0,u=0,l=0,i;
    printf("enter a string");
    fgets(a,sizeof(a),stdin);
    a[strcspn(a,"\n")]='\0';
    for(i=0;a[i]!=0;i++)
    {
        len++;
        if(a[i]>='A'&&a[i]<='Z')
     {
        u++;
     }
       else if(a[i]>='a'&&a[i]<='z')
         {
           l++;
         }
    }
    
    printf("%d upper\n %d lower \n %d length",u,l,len);
    return 0;
}
